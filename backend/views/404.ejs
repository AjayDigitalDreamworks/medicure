<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= message %> - Medicure</title>
  <style>
    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: 'Segoe UI', sans-serif;
      background: #f4fdfb;
      color: #2e2e2e;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .container {
      text-align: center;
    }

    .container img {
      max-width: 300px;
      margin-bottom: 30px;
    }

    h1 {
      font-size: 3rem;
      color: #00a97f;
      margin-bottom: 10px;
    }

    p {
      font-size: 1.2rem;
      margin-bottom: 30px;
      color: #555;
    }

    a {
      display: inline-block;
      padding: 12px 24px;
      background-color: #00a97f;
      color: white;
      text-decoration: none;
      border-radius: 6px;
      transition: background-color 0.3s ease;
    }

    a:hover {
      background-color: #008f6b;
    }

    @media (max-width: 600px) {
      h1 {
        font-size: 2rem;
      }

      p {
        font-size: 1rem;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <img src="<%= urlimg%>" alt="Not Found Icon" />
    <h1><%= message %></h1>
    <p><%= tagline %></p>
    <a href="/">Return to Home</a>
  </div>
</body>
</html>
